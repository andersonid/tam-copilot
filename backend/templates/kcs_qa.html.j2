<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>{{ data.title | default("KCS Q/A") }}</title>
<style>
@import url('https://fonts.googleapis.com/css2?family=Red+Hat+Display:wght@400;500;600;700;900&family=Red+Hat+Text:wght@400;500;600;700&family=Red+Hat+Mono:wght@400;500;600;700&display=swap');

:root {
  --rh-red: #EE0000;
  --rh-red-dark: #A30000;
  --rh-black: #151515;
  --rh-gray-95: #151515;
  --rh-gray-900: #1F1F1F;
  --rh-gray-700: #3C3F42;
  --rh-gray-500: #6A6E73;
  --rh-gray-300: #D2D2D2;
  --rh-gray-100: #F0F0F0;
  --rh-white: #FFFFFF;
  --rh-blue: #0066CC;
  --rh-blue-light: #E0F0FF;
}

*, *::before, *::after { margin: 0; padding: 0; box-sizing: border-box; }

body {
  font-family: 'Red Hat Text', sans-serif;
  font-size: 15px;
  color: var(--rh-gray-900);
  background: var(--rh-gray-100);
  line-height: 1.6;
}

.top-bar {
  background: var(--rh-gray-95);
  color: var(--rh-white);
  padding: 12px 40px;
  display: flex;
  align-items: center;
  gap: 16px;
  position: sticky;
  top: 0;
  z-index: 100;
}
.top-bar .divider { width: 1px; height: 20px; background: rgba(255,255,255,0.25); }
.top-bar .nav-label { font-size: 13px; color: rgba(255,255,255,0.6); font-weight: 500; }

.hero {
  background: linear-gradient(135deg, var(--rh-gray-95) 0%, #1a1a2e 50%, #16213e 100%);
  color: var(--rh-white);
  padding: 60px 40px 50px;
  position: relative;
  overflow: hidden;
}
.hero::after {
  content: '';
  position: absolute;
  top: -50%; right: -10%;
  width: 500px; height: 500px;
  background: radial-gradient(circle, rgba(238,0,0,0.12) 0%, transparent 70%);
  border-radius: 50%;
}
.hero .tag {
  display: inline-block;
  background: rgba(238,0,0,0.25);
  border: 1px solid rgba(238,0,0,0.5);
  color: #ff6b6b;
  font-family: 'Red Hat Mono', monospace;
  font-size: 11px; font-weight: 700;
  letter-spacing: 1.5px; text-transform: uppercase;
  padding: 4px 12px; border-radius: 3px;
  margin-bottom: 20px;
}
.hero h1 {
  font-family: 'Red Hat Display', sans-serif;
  font-weight: 900; font-size: 38px; line-height: 1.15;
  margin-bottom: 12px; position: relative; z-index: 1;
}
.hero .subtitle {
  font-size: 17px; color: rgba(255,255,255,0.7);
  font-weight: 400; max-width: 720px;
  position: relative; z-index: 1;
}
.hero .meta-row {
  display: flex; gap: 32px; margin-top: 28px;
  flex-wrap: wrap; position: relative; z-index: 1;
}
.hero .meta-item { display: flex; align-items: center; gap: 8px; font-size: 13px; color: rgba(255,255,255,0.6); }
.hero .meta-item strong { color: rgba(255,255,255,0.9); }

.kcs-container { max-width: 860px; margin: 0 auto; padding: 2rem; }

.abstract-card {
  background: var(--rh-blue-light);
  border: 1px solid var(--rh-blue);
  border-left: 4px solid var(--rh-blue);
  border-radius: 6px;
  padding: 18px 22px;
  margin-bottom: 2rem;
  font-size: 15px;
}

.answer-section {
  background: var(--rh-white);
  border: 1px solid var(--rh-gray-300);
  border-radius: 6px;
  margin-bottom: 20px;
  overflow: hidden;
}
.answer-header {
  background: var(--rh-gray-100);
  border-bottom: 1px solid var(--rh-gray-300);
  padding: 14px 22px;
  display: flex;
  align-items: center;
  gap: 10px;
}
.answer-num {
  font-family: 'Red Hat Mono', monospace;
  font-size: 12px; font-weight: 700;
  color: var(--rh-white);
  background: var(--rh-blue);
  min-width: 28px; height: 28px;
  border-radius: 999px;
  display: flex; align-items: center; justify-content: center;
}
.answer-header h2 {
  font-family: 'Red Hat Display', sans-serif;
  font-weight: 700; font-size: 18px; color: var(--rh-black);
  margin: 0; padding: 0; border: none;
}
.answer-body {
  padding: 22px;
  line-height: 1.7;
}
.answer-body p { margin-bottom: 0.75rem; }
.answer-body ul, .answer-body ol { padding-left: 1.5rem; margin-bottom: 0.75rem; }
.answer-body li { margin-bottom: 0.4rem; }
.answer-body code { font-family: 'Red Hat Mono', monospace; background: var(--rh-gray-100); padding: 0.1rem 0.35rem; border-radius: 3px; font-size: 0.9em; }
.answer-body pre { background: var(--rh-gray-95); color: #E0E0E0; padding: 1rem; border-radius: 4px; overflow-x: auto; font-family: 'Red Hat Mono', monospace; font-size: 0.9rem; margin: 0.75rem 0; border-left: 4px solid var(--rh-blue); }

.kcs-footer {
  background: var(--rh-gray-95);
  color: #a3a3a3;
  text-align: center;
  padding: 16px 40px;
  font-size: 0.75rem;
  margin-top: 2rem;
}
.kcs-footer a { color: #c7c7c7; text-decoration: none; }

@media print {
  .top-bar { position: static; }
  body { background: white; }
  .answer-section { break-inside: avoid; }
}
</style>
</head>
<body>

<div class="top-bar">
  <img src="https://static.redhat.com/libs/redhat/brand-assets/2/corp/logo--on-dark.svg" alt="Red Hat" height="32">
  <div class="divider"></div>
  <div class="nav-label">{{ data.title | default("KCS Q/A") }}</div>
  {% if data.get('meta', {}).get('customer') %}
  <div class="divider"></div>
  <div class="nav-label">{{ data.meta.customer }}</div>
  {% endif %}
</div>

<div class="hero">
  <div class="tag">{{ data.get('meta', {}).get('doc_type_label', 'KCS Q/A') }}</div>
  <h1>{{ data.title }}</h1>
  {% if data.get('subtitle') %}
  <p class="subtitle">{{ data.subtitle }}</p>
  {% endif %}
  {% set meta = data.get('meta', {}) %}
  {% if meta %}
  <div class="meta-row">
    {% if meta.get('customer') %}<div class="meta-item"><strong>Customer:</strong> {{ meta.customer }}</div>{% endif %}
    {% if meta.get('product') %}<div class="meta-item"><strong>Product:</strong> {{ meta.product }}</div>{% endif %}
    {% if meta.get('environment') %}<div class="meta-item"><strong>Environment:</strong> {{ meta.environment }}</div>{% endif %}
    {% if meta.get('date') %}<div class="meta-item"><strong>Date:</strong> {{ meta.date }}</div>{% endif %}
    {% for kv in meta.get('extra', []) %}
    <div class="meta-item"><strong>{{ kv.key }}:</strong> {{ kv.value }}</div>
    {% endfor %}
  </div>
  {% endif %}
</div>

<div class="kcs-container">

{% if data.get('abstract') %}
<div class="abstract-card">{{ data.abstract }}</div>
{% endif %}

{% for answer in data.get('answers', []) %}
<div class="answer-section">
  <div class="answer-header">
    <div class="answer-num">{{ loop.index }}</div>
    <h2>{{ answer.heading }}</h2>
  </div>
  <div class="answer-body">
    <p>{{ answer.content }}</p>
  </div>
</div>
{% endfor %}

<div class="kcs-footer">
  KCS Q/A Article &mdash; Generated by TAM-Copilot &mdash; &copy; Red Hat, Inc.
  {% if data.get('meta', {}).get('author') %}&mdash; {{ data.meta.author }}{% endif %}
</div>

</div>
</body>
</html>
