<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>{{ data.title | default("KCS Troubleshooting Guide") }}</title>
<style>
@import url('https://fonts.googleapis.com/css2?family=Red+Hat+Display:wght@400;500;600;700;900&family=Red+Hat+Text:wght@400;500;600;700&family=Red+Hat+Mono:wght@400;500;600;700&display=swap');

:root {
  --rh-red: #EE0000;
  --rh-red-dark: #A30000;
  --rh-black: #151515;
  --rh-gray-95: #151515;
  --rh-gray-900: #1F1F1F;
  --rh-gray-700: #3C3F42;
  --rh-gray-500: #6A6E73;
  --rh-gray-300: #D2D2D2;
  --rh-gray-100: #F0F0F0;
  --rh-white: #FFFFFF;
  --rh-blue: #0066CC;
  --rh-blue-light: #E0F0FF;
  --rh-orange: #EC7A08;
  --rh-orange-light: #FFE8CC;
  --rh-green: #3E8635;
  --rh-green-light: #E9F7DF;
  --rh-teal: #009596;
  --rh-teal-light: #DAF2F2;
  --danger: #C9190B;
  --danger-light: #FCE3E1;
}

*, *::before, *::after { margin: 0; padding: 0; box-sizing: border-box; }

body {
  font-family: 'Red Hat Text', sans-serif;
  font-size: 15px;
  color: var(--rh-gray-900);
  background: var(--rh-gray-100);
  line-height: 1.6;
}

.top-bar {
  background: var(--rh-gray-95);
  color: var(--rh-white);
  padding: 12px 40px;
  display: flex;
  align-items: center;
  gap: 16px;
  position: sticky;
  top: 0;
  z-index: 100;
}
.top-bar .divider { width: 1px; height: 20px; background: rgba(255,255,255,0.25); }
.top-bar .nav-label { font-size: 13px; color: rgba(255,255,255,0.6); font-weight: 500; }

.hero {
  background: linear-gradient(135deg, var(--rh-gray-95) 0%, #1a1a2e 50%, #16213e 100%);
  color: var(--rh-white);
  padding: 60px 40px 50px;
  position: relative;
  overflow: hidden;
}
.hero::after {
  content: '';
  position: absolute;
  top: -50%; right: -10%;
  width: 500px; height: 500px;
  background: radial-gradient(circle, rgba(238,0,0,0.12) 0%, transparent 70%);
  border-radius: 50%;
}
.hero .tag {
  display: inline-block;
  background: rgba(238,0,0,0.25);
  border: 1px solid rgba(238,0,0,0.5);
  color: #ff6b6b;
  font-family: 'Red Hat Mono', monospace;
  font-size: 11px; font-weight: 700;
  letter-spacing: 1.5px; text-transform: uppercase;
  padding: 4px 12px; border-radius: 3px;
  margin-bottom: 20px;
}
.hero h1 {
  font-family: 'Red Hat Display', sans-serif;
  font-weight: 900; font-size: 38px; line-height: 1.15;
  margin-bottom: 12px; position: relative; z-index: 1;
}
.hero .subtitle {
  font-size: 17px; color: rgba(255,255,255,0.7);
  font-weight: 400; max-width: 720px;
  position: relative; z-index: 1;
}
.hero .meta-row {
  display: flex; gap: 32px; margin-top: 28px;
  flex-wrap: wrap; position: relative; z-index: 1;
}
.hero .meta-item { display: flex; align-items: center; gap: 8px; font-size: 13px; color: rgba(255,255,255,0.6); }
.hero .meta-item strong { color: rgba(255,255,255,0.9); }

.kcs-container { max-width: 900px; margin: 0 auto; padding: 2rem; }

.abstract-card {
  background: var(--rh-orange-light);
  border: 1px solid var(--rh-orange);
  border-left: 4px solid var(--rh-orange);
  border-radius: 6px;
  padding: 18px 22px;
  margin-bottom: 2rem;
  font-size: 15px;
}

.diag-path {
  background: var(--rh-white);
  border: 1px solid var(--rh-gray-300);
  border-radius: 6px;
  margin-bottom: 24px;
  overflow: hidden;
}
.diag-header {
  background: var(--danger-light);
  border-bottom: 1px solid var(--rh-gray-300);
  padding: 14px 22px;
  display: flex;
  align-items: center;
  gap: 12px;
}
.diag-num {
  font-family: 'Red Hat Mono', monospace;
  font-size: 12px; font-weight: 700;
  color: var(--rh-white);
  background: var(--danger);
  min-width: 28px; height: 28px;
  border-radius: 999px;
  display: flex; align-items: center; justify-content: center;
}
.diag-header h2 {
  font-family: 'Red Hat Display', sans-serif;
  font-weight: 700; font-size: 16px; color: var(--rh-black);
  margin: 0; padding: 0; border: none;
  flex: 1;
}
.diag-body { padding: 22px; }

.diag-sub { margin-bottom: 16px; }
.diag-sub h3 {
  font-family: 'Red Hat Display', sans-serif;
  font-size: 13px; font-weight: 700;
  text-transform: uppercase; letter-spacing: 0.5px;
  color: var(--rh-gray-500);
  margin-bottom: 8px;
}

.check-list { list-style: none; padding: 0; counter-reset: chk; }
.check-list li {
  counter-increment: chk;
  padding: 8px 0 8px 36px;
  position: relative;
  border-bottom: 1px solid var(--rh-gray-100);
  font-size: 14px;
}
.check-list li:last-child { border-bottom: none; }
.check-list li::before {
  content: counter(chk);
  position: absolute; left: 0; top: 8px;
  font-family: 'Red Hat Mono', monospace;
  font-size: 11px; font-weight: 700;
  background: var(--rh-teal); color: var(--rh-white);
  width: 22px; height: 22px; border-radius: 50%;
  display: flex; align-items: center; justify-content: center;
}

.resolution-box {
  background: var(--rh-green-light);
  border: 1px solid var(--rh-green);
  border-left: 4px solid var(--rh-green);
  border-radius: 4px;
  padding: 14px 18px;
  font-size: 14px;
}

.related-links {
  list-style: none; padding: 0; margin-top: 8px;
}
.related-links li {
  font-size: 13px; color: var(--rh-gray-500);
  padding: 2px 0;
}
.related-links li::before {
  content: "→"; color: var(--rh-blue);
  font-weight: 700; margin-right: 6px;
}

.recommendations {
  background: var(--rh-blue-light);
  border: 1px solid var(--rh-blue);
  border-left: 4px solid var(--rh-blue);
  border-radius: 6px;
  padding: 18px 22px;
  margin-top: 12px;
}
.recommendations h2 {
  font-family: 'Red Hat Display', sans-serif;
  font-size: 16px; font-weight: 700;
  color: var(--rh-black);
  margin: 0 0 12px; padding: 0; border: none;
}
.recommendations ul { padding-left: 1.5rem; }
.recommendations li { margin-bottom: 6px; font-size: 14px; }

code { font-family: 'Red Hat Mono', monospace; }
p code, li code { background: var(--rh-gray-100); padding: 0.1rem 0.35rem; border-radius: 3px; font-size: 0.9em; }
pre { background: var(--rh-gray-95); color: #E0E0E0; padding: 1rem; border-radius: 4px; overflow-x: auto; font-family: 'Red Hat Mono', monospace; font-size: 0.9rem; margin: 0.75rem 0; border-left: 4px solid var(--danger); }

.kcs-footer {
  background: var(--rh-gray-95);
  color: #a3a3a3;
  text-align: center;
  padding: 16px 40px;
  font-size: 0.75rem;
  margin-top: 2rem;
}

@media print {
  .top-bar { position: static; }
  body { background: white; }
  .diag-path { break-inside: avoid; }
}
</style>
</head>
<body>

<div class="top-bar">
  <img src="https://static.redhat.com/libs/redhat/brand-assets/2/corp/logo--on-dark.svg" alt="Red Hat" height="32">
  <div class="divider"></div>
  <div class="nav-label">{{ data.title | default("KCS Troubleshooting Guide") }}</div>
  {% if data.get('meta', {}).get('customer') %}
  <div class="divider"></div>
  <div class="nav-label">{{ data.meta.customer }}</div>
  {% endif %}
</div>

<div class="hero">
  <div class="tag">{{ data.get('meta', {}).get('doc_type_label', 'KCS TROUBLESHOOTING GUIDE') }}</div>
  <h1>{{ data.title }}</h1>
  {% if data.get('subtitle') %}
  <p class="subtitle">{{ data.subtitle }}</p>
  {% endif %}
  {% set meta = data.get('meta', {}) %}
  {% if meta %}
  <div class="meta-row">
    {% if meta.get('customer') %}<div class="meta-item"><strong>Customer:</strong> {{ meta.customer }}</div>{% endif %}
    {% if meta.get('product') %}<div class="meta-item"><strong>Product:</strong> {{ meta.product }}</div>{% endif %}
    {% if meta.get('environment') %}<div class="meta-item"><strong>Environment:</strong> {{ meta.environment }}</div>{% endif %}
    {% if meta.get('date') %}<div class="meta-item"><strong>Date:</strong> {{ meta.date }}</div>{% endif %}
    {% for kv in meta.get('extra', []) %}
    <div class="meta-item"><strong>{{ kv.key }}:</strong> {{ kv.value }}</div>
    {% endfor %}
  </div>
  {% endif %}
</div>

<div class="kcs-container">

{% if data.get('abstract') %}
<div class="abstract-card">{{ data.abstract }}</div>
{% endif %}

{% for path in data.get('diagnostic_paths', []) %}
<div class="diag-path">
  <div class="diag-header">
    <div class="diag-num">{{ loop.index }}</div>
    <h2>{{ path.symptom }}</h2>
  </div>
  <div class="diag-body">
    {% if path.get('checks') %}
    <div class="diag-sub">
      <h3>Diagnostic Checks</h3>
      <ol class="check-list">
        {% for check in path.checks %}
        <li>{{ check }}</li>
        {% endfor %}
      </ol>
    </div>
    {% endif %}

    {% if path.get('resolution') %}
    <div class="diag-sub">
      <h3>Resolution</h3>
      <div class="resolution-box">{{ path.resolution }}</div>
    </div>
    {% endif %}

    {% if path.get('related_articles') %}
    <div class="diag-sub">
      <h3>Related Articles</h3>
      <ul class="related-links">
        {% for ref in path.related_articles %}
        <li>{{ ref }}</li>
        {% endfor %}
      </ul>
    </div>
    {% endif %}
  </div>
</div>
{% endfor %}

{% if data.get('general_recommendations') %}
<div class="recommendations">
  <h2>General Recommendations</h2>
  <ul>
    {% for rec in data.general_recommendations %}
    <li>{{ rec }}</li>
    {% endfor %}
  </ul>
</div>
{% endif %}

<div class="kcs-footer">
  KCS Troubleshooting Guide &mdash; Generated by TAM-Copilot &mdash; &copy; Red Hat, Inc.
  {% if data.get('meta', {}).get('author') %}&mdash; {{ data.meta.author }}{% endif %}
</div>

</div>
</body>
</html>
