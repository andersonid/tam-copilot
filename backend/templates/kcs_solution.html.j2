<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>{{ data.title | default("KCS Solution") }}</title>
<style>
@import url('https://fonts.googleapis.com/css2?family=Red+Hat+Display:wght@400;500;600;700;900&family=Red+Hat+Text:wght@400;500;600;700&family=Red+Hat+Mono:wght@400;500;600;700&display=swap');

:root {
  --rh-red: #EE0000;
  --rh-red-dark: #A30000;
  --rh-black: #151515;
  --rh-gray-95: #151515;
  --rh-gray-900: #1F1F1F;
  --rh-gray-700: #3C3F42;
  --rh-gray-500: #6A6E73;
  --rh-gray-300: #D2D2D2;
  --rh-gray-100: #F0F0F0;
  --rh-white: #FFFFFF;
}

*, *::before, *::after { margin: 0; padding: 0; box-sizing: border-box; }

body {
  font-family: 'Red Hat Text', sans-serif;
  font-size: 15px;
  color: var(--rh-gray-900);
  background: var(--rh-white);
  line-height: 1.6;
}

.top-bar {
  background: var(--rh-gray-95);
  color: var(--rh-white);
  padding: 12px 40px;
  display: flex;
  align-items: center;
  gap: 16px;
  position: sticky;
  top: 0;
  z-index: 100;
}
.top-bar .divider { width: 1px; height: 20px; background: rgba(255,255,255,0.25); }
.top-bar .nav-label { font-size: 13px; color: rgba(255,255,255,0.6); font-weight: 500; }

.hero {
  background: linear-gradient(135deg, var(--rh-gray-95) 0%, #1a1a2e 50%, #16213e 100%);
  color: var(--rh-white);
  padding: 60px 40px 50px;
  position: relative;
  overflow: hidden;
}
.hero::after {
  content: '';
  position: absolute;
  top: -50%; right: -10%;
  width: 500px; height: 500px;
  background: radial-gradient(circle, rgba(238,0,0,0.12) 0%, transparent 70%);
  border-radius: 50%;
}
.hero .tag {
  display: inline-block;
  background: rgba(238,0,0,0.25);
  border: 1px solid rgba(238,0,0,0.5);
  color: #ff6b6b;
  font-family: 'Red Hat Mono', monospace;
  font-size: 11px; font-weight: 700;
  letter-spacing: 1.5px; text-transform: uppercase;
  padding: 4px 12px; border-radius: 3px;
  margin-bottom: 20px;
}
.hero h1 {
  font-family: 'Red Hat Display', sans-serif;
  font-weight: 900; font-size: 38px; line-height: 1.15;
  margin-bottom: 12px; position: relative; z-index: 1;
}
.hero .subtitle {
  font-size: 17px; color: rgba(255,255,255,0.7);
  font-weight: 400; max-width: 720px;
  position: relative; z-index: 1;
}
.hero .meta-row {
  display: flex; gap: 32px; margin-top: 28px;
  flex-wrap: wrap; position: relative; z-index: 1;
}
.hero .meta-item { display: flex; align-items: center; gap: 8px; font-size: 13px; color: rgba(255,255,255,0.6); }
.hero .meta-item strong { color: rgba(255,255,255,0.9); }

.kcs-container { max-width: 800px; margin: 0 auto; padding: 2rem; }

.kcs-section { margin-bottom: 2rem; }
.kcs-section h2 {
  font-family: 'Red Hat Display', sans-serif;
  font-size: 1.2rem;
  font-weight: 700;
  color: var(--rh-black);
  padding: 0.5rem 0;
  border-bottom: 1px solid var(--rh-gray-300);
  margin-bottom: 1rem;
}

.kcs-section ul { padding-left: 1.5rem; }
.kcs-section ul li { margin-bottom: 0.5rem; }
.kcs-section ol { padding-left: 1.5rem; }
.kcs-section ol li { margin-bottom: 0.5rem; }

pre { background: var(--rh-gray-100); color: var(--rh-gray-900); padding: 1rem; border-radius: 4px; overflow-x: auto; font-family: 'Red Hat Mono', monospace; font-size: 0.9rem; margin: 0.75rem 0; border: 1px solid var(--rh-gray-300); }
code { font-family: 'Red Hat Mono', monospace; }
p code, li code { background: var(--rh-gray-100); padding: 0.1rem 0.35rem; border-radius: 3px; font-size: 0.9em; }

.kcs-footer { text-align: center; padding: 1.5rem 0; color: var(--rh-gray-500); font-size: 0.8rem; border-top: 1px solid var(--rh-gray-300); margin-top: 2rem; }
</style>
</head>
<body>

<div class="top-bar">
  <img src="https://static.redhat.com/libs/redhat/brand-assets/2/corp/logo--on-dark.svg" alt="Red Hat" height="32">
  <div class="divider"></div>
  <div class="nav-label">{{ data.title | default("KCS Solution") }}</div>
  {% if data.get('meta', {}).get('customer') %}
  <div class="divider"></div>
  <div class="nav-label">{{ data.meta.customer }}</div>
  {% endif %}
</div>

<div class="hero">
  <div class="tag">KCS Solution</div>
  <h1>{{ data.title }}</h1>
  {% if data.get('subtitle') %}
  <p class="subtitle">{{ data.subtitle }}</p>
  {% endif %}
  {% set meta = data.get('meta', {}) %}
  {% if meta %}
  <div class="meta-row">
    {% if meta.get('customer') %}<div class="meta-item"><strong>Customer:</strong> {{ meta.customer }}</div>{% endif %}
    {% if meta.get('product') %}<div class="meta-item"><strong>Product:</strong> {{ meta.product }}</div>{% endif %}
    {% if meta.get('environment') %}<div class="meta-item"><strong>Environment:</strong> {{ meta.environment }}</div>{% endif %}
    {% if meta.get('date') %}<div class="meta-item"><strong>Date:</strong> {{ meta.date }}</div>{% endif %}
    {% for kv in meta.get('extra', []) %}
    <div class="meta-item"><strong>{{ kv.key }}:</strong> {{ kv.value }}</div>
    {% endfor %}
  </div>
  {% endif %}
</div>

<div class="kcs-container">

<div class="kcs-section">
  <h2>Issue</h2>
  <ul>
    {% for item in data.get('issue', []) %}
    <li>{{ item }}</li>
    {% endfor %}
  </ul>
</div>

<div class="kcs-section">
  <h2>Environment</h2>
  <ul>
    {% for item in data.get('environment', []) %}
    <li>{{ item }}</li>
    {% endfor %}
  </ul>
</div>

<div class="kcs-section">
  <h2>Resolution</h2>
  <ol>
    {% for item in data.get('resolution', []) %}
    <li>{{ item }}</li>
    {% endfor %}
  </ol>
</div>

{% if data.get('root_cause') %}
<div class="kcs-section">
  <h2>Root Cause</h2>
  <p>{{ data.root_cause }}</p>
</div>
{% endif %}

{% if data.get('diagnostic_steps') %}
<div class="kcs-section">
  <h2>Diagnostic Steps</h2>
  <ol>
    {% for item in data.diagnostic_steps %}
    <li>{{ item }}</li>
    {% endfor %}
  </ol>
</div>
{% endif %}

<div class="kcs-footer">
  <strong>RED HAT</strong> KCS Article — Generated by TAM-Copilot
</div>

</div>
</body>
</html>
