<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>{{ data.title | default("KCS How-to") }}</title>
<style>
@import url('https://fonts.googleapis.com/css2?family=Red+Hat+Display:wght@400;500;700;900&family=Red+Hat+Text:wght@400;500;700&family=Red+Hat+Mono:wght@400;500;700&display=swap');
:root { --rh-red: #EE0000; --rh-red-dark: #A30000; --rh-black: #151515; --rh-gray-900: #1F1F1F; --rh-gray-700: #3C3F42; --rh-gray-500: #6A6E73; --rh-gray-300: #D2D2D2; --rh-gray-100: #F0F0F0; --rh-white: #FFFFFF; }
*, *::before, *::after { margin: 0; padding: 0; box-sizing: border-box; }
body { font-family: 'Red Hat Text', sans-serif; color: var(--rh-gray-900); background: var(--rh-white); line-height: 1.6; }
.kcs-container { max-width: 800px; margin: 0 auto; padding: 2rem; }
.kcs-header { border-bottom: 3px solid var(--rh-red); padding-bottom: 1.5rem; margin-bottom: 2rem; }
.kcs-header .rh-logo { font-family: 'Red Hat Display', sans-serif; font-weight: 900; color: var(--rh-red); font-size: 0.85rem; letter-spacing: 0.05em; margin-bottom: 0.75rem; }
.kcs-header h1 { font-family: 'Red Hat Display', sans-serif; font-size: 1.75rem; font-weight: 700; color: var(--rh-black); }
.kcs-header .article-type { display: inline-block; background: var(--rh-red-dark); color: white; padding: 0.2rem 0.75rem; border-radius: 3px; font-size: 0.8rem; font-weight: 600; margin-top: 0.75rem; }
.kcs-section { margin-bottom: 2rem; }
.kcs-section h2 { font-family: 'Red Hat Display', sans-serif; font-size: 1.2rem; font-weight: 700; color: var(--rh-black); padding: 0.5rem 0; border-bottom: 1px solid var(--rh-gray-300); margin-bottom: 1rem; }
.kcs-section ol { padding-left: 1.5rem; }
.kcs-section ol li { margin-bottom: 0.5rem; }
pre { background: var(--rh-gray-100); padding: 1rem; border-radius: 4px; overflow-x: auto; font-family: 'Red Hat Mono', monospace; font-size: 0.9rem; margin: 0.75rem 0; border: 1px solid var(--rh-gray-300); }
code { font-family: 'Red Hat Mono', monospace; }
p code, li code { background: var(--rh-gray-100); padding: 0.1rem 0.35rem; border-radius: 3px; font-size: 0.9em; }
.kcs-footer { text-align: center; padding: 1.5rem 0; color: var(--rh-gray-500); font-size: 0.8rem; border-top: 1px solid var(--rh-gray-300); margin-top: 2rem; }
</style>
</head>
<body>
<div class="kcs-container">
<div class="kcs-header">
  <div class="rh-logo">RED HAT KNOWLEDGE BASE</div>
  <h1>{{ data.title }}</h1>
  <span class="article-type">HOW-TO</span>
</div>

{% if data.get('abstract') %}
<div class="kcs-section">
  <h2>Abstract</h2>
  <p>{{ data.abstract }}</p>
</div>
{% endif %}

<div class="kcs-section">
  <h2>Steps</h2>
  <ol>
    {% for item in data.get('steps', []) %}
    <li>{{ item }}</li>
    {% endfor %}
  </ol>
</div>

{% if data.get('elaboration') %}
<div class="kcs-section">
  <h2>Additional Notes</h2>
  <p>{{ data.elaboration }}</p>
</div>
{% endif %}

<div class="kcs-footer">
  <strong>RED HAT</strong> KCS Article — Generated by TAM-Copilot
</div>
</div>
</body>
</html>
