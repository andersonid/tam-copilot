# Default LLM provider (seeded on first run, editable via UI after)
DEFAULT_PROVIDER_NAME=LiteMaaS
DEFAULT_PROVIDER_TYPE=openai_compatible
DEFAULT_PROVIDER_BASE_URL=https://litellm-prod.apps.maas.redhatworkshops.io
DEFAULT_PROVIDER_API_KEY=your-api-key-here
DEFAULT_PROVIDER_MODEL=qwen3-14b

# App config
DATABASE_URL=sqlite+aiosqlite:///./data/tam_copilot.db
DATA_DIR=./data
SECRET_KEY=change-me-in-production

# Embeddings
EMBEDDING_MODEL=nomic-embed-text-v1-5
SIMILARITY_THRESHOLD=0.82
